/* === MAIN INPUT MODIFIER === */

const modifier = (text) => {

  if (state.heat === undefined) {
    state.heat = state.initialHeatValue
    state.cooldownMode = false
    state.overheatMode = false
  }

  if (state.storyTemperature === undefined) {
    state.storyTemperature = state.initialTemperatureValue
  }

  const lowerText = text.toLowerCase()
  const words = lowerText.split(/\s+/)

  let conflictCount = 0
  let calmingCount = 0

  words.forEach(word => {
    const fixedWord = word.replace(/^[^\w]+|[^\w]+$/g,'')
    if (conflictWords.includes(fixedWord)) conflictCount++
    if (calmingWords.includes(fixedWord)) calmingCount++
  })


  /* PLAYER EFFECTS */

  if (!state.cooldownMode) {

    if (conflictCount > 0) {

      state.heat += conflictCount * state.playerIncreaseHeatImpact

      if (conflictCount >= state.threshholdPlayerIncreaseTemperature) {
        state.storyTemperature += conflictCount * state.playerIncreaseTemperatureImpact
        log(`Player conflict detected (${conflictCount})`)
      }

    }

    if (calmingCount > 0) {

      state.heat -= calmingCount * state.playerDecreaseHeatImpact

      if (calmingCount >= state.threshholdPlayerDecreaseTemperature) {
        state.storyTemperature -= calmingCount * state.playerDecreaseTemperatureImpact
        log(`Player calming detected (${calmingCount})`)
      }

    }

  }

  /* PREVENT NEGATIVE HEAT */

  if (state.heat < 0) {
    state.heat = 0
  }

  /* RANDOM CHAOS EVENT */

  state.chance = randomint(1,100)

  if (state.chance <= state.randomExplosionChance) {

    state.heat += state.randomExplosionHeatIncreaseValue
    state.storyTemperature += state.randomExplosionTemperatureIncreaseValue

    log("Random escalation event triggered")

  }


  /* HEAT BUILDUP */

  if (!state.cooldownMode && !state.overheatMode) {

    state.heat += state.heatIncreaseValue

  }


  /* TEMPERATURE INCREASE */

  state.chance = randomint(1, state.temperatureIncreaseChance)

  if (state.chance <= state.heat) {

    state.heat = 0
    state.storyTemperature += state.temperatureIncreaseValue

  }


  /* OVERHEAT TRIGGER */

  if (state.storyTemperature >= state.maximumTemperature) {

    if (!state.cooldownMode && !state.overheatMode) {

      state.overheatMode = true
      state.overheatTurnsLeft = state.overheatTimer

    }

  }


  /* COOLDOWN + OVERHEAT SYSTEM */

  if (state.cooldownMode) {

    state.cooldownTurnsLeft--
    state.storyTemperature -= state.cooldownRate

    if (state.cooldownTurnsLeft <= 0) {
      state.cooldownMode = false
    }

  } else {

    if (state.overheatMode) {

      state.overheatTurnsLeft--

      if (state.overheatTurnsLeft <= 0) {

        state.storyTemperature -= state.overheatReductionForTemperature
        state.heat -= state.overheatReductionForHeat

        state.overheatMode = false
        state.cooldownMode = true
        state.cooldownTurnsLeft = state.cooldownTimer

      }

    }

  }


  /* TEMPERATURE LIMITS */

  if (state.storyTemperature > state.trueMaximumTemperature) {
    state.storyTemperature = state.trueMaximumTemperature
  }

  if (state.storyTemperature < state.trueMinimumTemperature) {
    state.storyTemperature = state.trueMinimumTemperature
  }


  /* STORY PHASE PROMPTS */

  if (!state.cooldownMode) {

    if (state.storyTemperature <= 2) {
      state.originalAuthorsNote = "Story Phase: Introduction. Establish characters, setting, and plot hooks."
    }

    else if (state.storyTemperature <= 5) {
      state.originalAuthorsNote = "Story Phase: Early Rising Action. Minor conflicts appear."
    }

    else if (state.storyTemperature <= 8) {
      state.originalAuthorsNote = "Story Phase: Rising Action. Moderate conflicts and plot developments."
    }

    else if (state.storyTemperature <= 11) {
      state.originalAuthorsNote = "Story Phase: High Rising Action. Conflicts intensify."
    }

    else {
      state.originalAuthorsNote = "Story Phase: Climax. Major conflicts dominate the story."
    }

  } else {

    if (state.storyTemperature <= 3) {
      state.originalAuthorsNote = "Story Phase: Downtime. Characters recover and reflect."
    }

    else if (state.storyTemperature <= 7) {
      state.originalAuthorsNote = "Story Phase: Falling Action. Conflicts begin resolving."
    }

    else {
      state.originalAuthorsNote = "Story Phase: Cooling Down. High tension slowly subsides."
    }

  }

  return { text }

}


