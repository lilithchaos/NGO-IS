if (typeof InnerSelf === "function") { InnerSelf("output"); }

const modifier = (text) => {
  if (!state.initialized) return { text };

  // 1. NGO Tracking (AI Side)
  const lowerText = text.toLowerCase();
  let cCount = 0;
  lowerText.split(/\s+/).forEach(w => {
    const fw = w.replace(/^[^\w]+|[^\w]+$/g, '');
    if (conflictWords.includes(fw)) cCount++;
  });

  if (cCount >= 3) {
    state.heat += 1;
    state.storyTemperature = Math.min(state.maximumTemperature, state.storyTemperature + 1);
  }

  // 2. Update FrontMemory/Dashboard
  state.memory.frontMemory = (state.roll?.action === info.actionCount - 1) ? state.roll.frontMemory : "";
  
  let dash = storyCards.find(c => c.title === "SYSTEM: Dashboard");
  let status = `HEAT: ${state.heat} | TEMP: ${state.storyTemperature} | ACTION: ${info.actionCount}`;
  if (dash) { dash.entry = status; } 
  else { addStoryCard("SYSTEM: Dashboard", status, "system"); }

  // IMPORTANT: Do NOT manually call AutoCards() here. 
  // InnerSelf("output") handles the return logic for you.
  return { text };
};
modifier(text);
