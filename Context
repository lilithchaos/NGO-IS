InnerSelf("context");

const modifier = (text) => {

  /* === INITIALIZE === */

  if (!state.initialized){

    state.phaseNote = "[Story Phase: Introduction]"

    state.initialized = true
  }

  /* === ENSURE PHASE NOTE EXISTS === */

  if (!state.phaseNote){
    state.phaseNote = "[Story Phase: Introduction]"
  }

  /* === PRESERVE INNERSELF AUTHOR'S NOTE === */

  let innerSelfNote = state.memory.authorsNote || ""

  /* === ADD PHASE NOTE WITHOUT OVERWRITING INNERSELF === */

  if (!innerSelfNote.includes(state.phaseNote)){

    state.memory.authorsNote =
      state.phaseNote + "\n" + innerSelfNote

  }

  return { text }

}

modifier(text)
